{
  "version": 2,
  "builds": [
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "informe-astral.png", "use": "@vercel/static" },
    { "src": "og-image.jpg", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/informe-astral.png", "dest": "/informe-astral.png" },
    { "src": "/og-image.jpg", "dest": "/og-image.jpg" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}